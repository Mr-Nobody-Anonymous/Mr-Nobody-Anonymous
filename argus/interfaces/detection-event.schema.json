{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://argus.local/schemas/detection-event.schema.json",
  "title": "ArgusDetectionEvent",
  "type": "object",
  "required": ["event_type", "camera_id", "timestamp", "lat", "lon"],
  "properties": {
    "event_type": {
      "type": "string",
      "enum": ["plate_detection", "face_detection", "movement_detection"]
    },
    "camera_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "plate": {
      "type": ["string", "null"]
    },
    "face_id": {
      "type": ["string", "null"]
    },
    "track_id": {
      "type": ["string", "null"]
    },
    "lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90
    },
    "lon": {
      "type": "number",
      "minimum": -180,
      "maximum": 180
    },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "raw_payload": {
      "type": ["object", "null"]
    }
  },
  "additionalProperties": false
}
